---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Carbide Saws Inc. - Professional saw repair and sharpening service in High Point, NC. Serving NC, SC, VA and Eastern TN since 1954." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&family=Roboto+Slab:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-gray-900 antialiased">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-primary border-b border-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center">
          <img src="/logo.png" alt="Carbide Saws Inc." class="h-12 w-auto" />
        </a>
        
        <!-- Desktop Menu -->
        <div class="hidden lg:flex space-x-6 items-center">
          <!-- Services Dropdown -->
          <div class="relative group">
            <button class="nav-link flex items-center">
              Services
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute top-full left-0 mt-2 w-64 bg-primary border border-secondary/50 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="py-2">
                <a href="/carbide-saw-sharpening" class="block px-4 py-3 text-gray-300 hover:text-accent hover:bg-white/5 transition">
                  <span class="font-semibold">Sharpening</span>
                  <span class="block text-sm text-gray-500">Precision CNC grinding</span>
                </a>
                <a href="/industrial-saw-repair" class="block px-4 py-3 text-gray-300 hover:text-accent hover:bg-white/5 transition">
                  <span class="font-semibold">Repair</span>
                  <span class="block text-sm text-gray-500">Tip replacement & restoration</span>
                </a>
                <a href="/custom-saw-blades" class="block px-4 py-3 text-gray-300 hover:text-accent hover:bg-white/5 transition">
                  <span class="font-semibold">Custom Blades</span>
                  <span class="block text-sm text-gray-500">Engineered to order</span>
                </a>
                <div class="border-t border-secondary/50 my-2"></div>
                <a href="/expert-advice" class="block px-4 py-3 text-gray-300 hover:text-accent hover:bg-white/5 transition">
                  <span class="font-semibold">Expert Advice</span>
                  <span class="block text-sm text-gray-500">Technical consulting</span>
                </a>
                <a href="/pickup-delivery" class="block px-4 py-3 text-gray-300 hover:text-accent hover:bg-white/5 transition">
                  <span class="font-semibold">Free Pickup & Delivery</span>
                  <span class="block text-sm text-gray-500">NC, SC, VA, Eastern TN</span>
                </a>
              </div>
            </div>
          </div>
          <a href="/circular-saw-blades" class="nav-link">Products</a>
          <a href="/locations" class="nav-link">Locations</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/contact" class="btn-primary">Contact Us</a>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="Toggle menu">
          <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden bg-primary border-t border-secondary/50">
      <div class="px-4 py-6 space-y-4">
        <div class="border-b border-secondary/50 pb-4">
          <span class="text-accent font-semibold uppercase tracking-wider text-sm">Services</span>
          <a href="/carbide-saw-sharpening" class="block text-gray-300 hover:text-accent py-2 text-lg pl-4">Sharpening</a>
          <a href="/industrial-saw-repair" class="block text-gray-300 hover:text-accent py-2 text-lg pl-4">Repair</a>
          <a href="/custom-saw-blades" class="block text-gray-300 hover:text-accent py-2 text-lg pl-4">Custom Blades</a>
          <a href="/expert-advice" class="block text-gray-300 hover:text-accent py-2 text-lg pl-4">Expert Advice</a>
          <a href="/pickup-delivery" class="block text-gray-300 hover:text-accent py-2 text-lg pl-4">Free Pickup & Delivery</a>
        </div>
        <a href="/circular-saw-blades" class="block text-gray-300 hover:text-accent py-2 text-lg">Products</a>
        <a href="/locations" class="block text-gray-300 hover:text-accent py-2 text-lg">Locations</a>
        <a href="/about" class="block text-gray-300 hover:text-accent py-2 text-lg">About</a>
        <a href="/contact" class="block btn-primary text-center mt-4">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="pt-20">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-primary text-white py-16 mt-20 border-t border-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8">
        <div>
          <img src="/logo.png" alt="Carbide Saws Inc." class="h-12 w-auto mb-4 brightness-200" />
          <p class="text-gray-400 leading-relaxed">
            Your GO-TO-SOURCE in the Eastern United States for saw blade manufacturing and servicing since 1954.
          </p>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent text-lg">Services</h4>
          <ul class="space-y-3 text-gray-400">
            <li><a href="/carbide-saw-sharpening" class="hover:text-accent transition">Saw Sharpening</a></li>
            <li><a href="/industrial-saw-repair" class="hover:text-accent transition">Blade Repair</a></li>
            <li><a href="/custom-saw-blades" class="hover:text-accent transition">Custom Manufacturing</a></li>
            <li><a href="/cold-saw-sharpening" class="hover:text-accent transition">Cold Saw Service</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent text-lg">Products</h4>
          <ul class="space-y-3 text-gray-400">
            <li><a href="/circular-saw-blades" class="hover:text-accent transition">Circular Blades</a></li>
            <li><a href="/band-saw-blades" class="hover:text-accent transition">Band Saw Blades</a></li>
            <li><a href="/carbide-saw-sharpening" class="hover:text-accent transition">Carbide Tipped</a></li>
            <li><a href="/custom-saw-blades" class="hover:text-accent transition">Custom Cutter Heads</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent text-lg">Contact</h4>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>701 Garrison St<br/>High Point, NC 27260</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:800-578-7197" class="hover:text-accent transition">(800) 578-7197</a>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:info@carbidesawsinc.com" class="hover:text-accent transition">info@carbidesawsinc.com</a>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Mon-Fri: 8AM - 5PM EST
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-secondary/50 mt-12 pt-8 text-center text-gray-500">
        <p>&copy; 2024 Carbide Saws Inc. All rights reserved. | Authorized Freud Service Center</p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
      menuIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });

    // Close menu when clicking a link
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });
  </script>
</body>
</html>
