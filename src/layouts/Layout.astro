---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Carbide Saws Inc. - Professional saw repair and sharpening service in High Point, NC. Serving NC, SC, VA and Eastern TN since 1954." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://philly88r.github.io/carbidesaws-rebuild');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-gray-900 antialiased">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-primary border-b border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <a href="/carbidesaws-rebuild/" class="flex items-center">
          <img src="/carbidesaws-rebuild/logo.png" alt="Carbide Saws Inc." class="h-14 w-auto" />
        </a>
        <div class="hidden md:flex space-x-8 items-center">
          <a href="/carbidesaws-rebuild/carbide-saw-sharpening" class="nav-link">Sharpening</a>
          <a href="/carbidesaws-rebuild/industrial-saw-repair" class="nav-link">Repair</a>
          <a href="/carbidesaws-rebuild/custom-saw-blades" class="nav-link">Custom Blades</a>
          <a href="/carbidesaws-rebuild/contact" class="btn-primary">Contact Us</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="pt-20">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-primary text-white py-12 mt-20 border-t border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8">
        <div>
          <img src="/carbidesaws-rebuild/logo.png" alt="Carbide Saws Inc." class="h-12 w-auto mb-4 brightness-200" />
          <p class="text-gray-400">Your GO-TO-SOURCE in the Eastern United States for saw blade manufacturing and servicing since 1954.</p>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent">Services</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href="/carbidesaws-rebuild/carbide-saw-sharpening" class="hover:text-accent transition">Saw Sharpening</a></li>
            <li><a href="/carbidesaws-rebuild/industrial-saw-repair" class="hover:text-accent transition">Blade Repair</a></li>
            <li><a href="/carbidesaws-rebuild/custom-saw-blades" class="hover:text-accent transition">Custom Manufacturing</a></li>
            <li><a href="/carbidesaws-rebuild/cold-saw-sharpening" class="hover:text-accent transition">Cold Saw Service</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent">Products</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href="/carbidesaws-rebuild/circular-saw-blades" class="hover:text-accent transition">Circular Blades</a></li>
            <li><a href="/carbidesaws-rebuild/band-saw-blades" class="hover:text-accent transition">Band Saw Blades</a></li>
            <li><a href="/carbidesaws-rebuild/carbide-saw-sharpening" class="hover:text-accent transition">Carbide Tipped</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-accent">Contact</h4>
          <ul class="space-y-2 text-gray-400">
            <li>High Point, NC</li>
            <li>Serving NC, SC, VA, Eastern TN</li>
            <li>Nationwide Shipping</li>
            <li><a href="/carbidesaws-rebuild/contact" class="hover:text-accent transition">Get a Quote</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-secondary mt-8 pt-8 text-center text-gray-500">
        <p>&copy; 2024 Carbide Saws Inc. All rights reserved. | Authorized Freud Service Center</p>
      </div>
    </div>
  </footer>
</body>
</html>
