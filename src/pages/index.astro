---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Carbide Saw Sharpening",
    description: "Precision CNC grinding with CBN and diamond wheels. Restore blade performance to OEM specifications with our expert sharpening services.",
    href: "/carbidesaws-rebuild/carbide-saw-sharpening",
    icon: "/carbidesaws-rebuild/icon-sharpening.png"
  },
  {
    title: "Industrial Saw Repair",
    description: "Complete blade restoration including tip replacement, tensioning, and geometry correction. We repair blades others discard.",
    href: "/carbidesaws-rebuild/industrial-saw-repair",
    icon: "/carbidesaws-rebuild/icon-repair.png"
  },
  {
    title: "Custom Saw Blades",
    description: "Engineered-to-order carbide and bi-metal blades designed specifically for your unique material and cutting requirements.",
    href: "/carbidesaws-rebuild/custom-saw-blades",
    icon: "/carbidesaws-rebuild/icon-custom.png"
  },
  {
    title: "Nationwide Service",
    description: "Pickup and delivery throughout NC, SC, VA, and Eastern Tennessee. We also ship nationwide for customers outside our local area.",
    href: "/carbidesaws-rebuild/contact",
    icon: "/carbidesaws-rebuild/icon-service.png"
  }
];

const testimonials = [
  {
    text: "Carbide Saws has been our go-to for blade sharpening for over 10 years. Their quality and turnaround time are unmatched.",
    author: "Industrial Woodworking Client"
  },
  {
    text: "The custom blades they manufactured for our specialty application outlasted anything we'd tried before. Highly recommended.",
    author: "Metal Fabrication Shop Owner"
  }
];
---

<Layout 
  title="Carbide Saws Inc. | Saw Repair and Sharpening Service High Point NC"
  description="In business since 1954, we are your GO-TO-SOURCE in the Eastern United States for the manufacture and servicing of saw blades and custom cutter heads. Authorized Freud service center."
>
  <!-- Hero Section -->
  <section class="gradient-hero text-white min-h-[90vh] flex items-center relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/carbidesaws-rebuild/gallery-1.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
      <div class="max-w-3xl">
        <div class="inline-block bg-accent/20 border border-accent/30 rounded-full px-4 py-2 mb-6">
          <span class="text-accent font-semibold text-sm tracking-wider uppercase">Serving the Eastern United States Since 1954</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold leading-tight mb-8 text-balance" style="font-family: 'Roboto Slab', serif;">
