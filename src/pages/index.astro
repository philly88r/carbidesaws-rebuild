          sharpening, retipping, re-tensioning, and cleaning of carbide tipped tooling.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {services.map(service => (
          <a href={service.href} class="group feature-card card-hover text-center">
            <div class="feature-icon mx-auto">
              <img src={service.icon} alt="" class="w-10 h-10 object-contain" />
