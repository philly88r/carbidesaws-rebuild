---
import Layout from '../layouts/Layout.astro';

const sharpeningTypes = [
  {
    title: "Carbide Tipped Circular Saws",
    description: "Precision grinding of carbide tipped circular saw blades using diamond wheels. We restore the original geometry including hook angle, clearance angle, and radial clearance.",
    specs: ["10\" to 84\" diameter", "All tooth configurations", "C-2, C-3, C-4 grades"]
  },
  {
    title: "Band Saw Blades",
    description: "Complete sharpening service for bi-metal and carbide tipped band saw blades. We maintain consistent tooth geometry throughout the blade length for optimal cutting performance.",
    specs: ["Bi-metal M42", "Carbide tipped", "All widths and pitches"]
  },
  {
    title: "Cold Saw Blades",
    description: "Specialized sharpening for HSS and cermet cold saw blades used in metal fabrication. We maintain the precise tooth geometry required for burr-free cuts.",
    specs: ["HSS blades", "Cermet blades", "Solid carbide"]
  },
  {
    title: "Router Bits & Shaper Cutters",
    description: "Precision sharpening of all types of router bits and shaper cutters. We restore cutting edges while maintaining the original profile and balance.",
    specs: ["Carbide tipped", "Solid carbide", "Custom profiles"]
  }
];

const processSteps = [
  {
    number: "01",
    title: "Inspection",
    description: "Each blade is thoroughly inspected for damage, wear patterns, and existing geometry. We identify any cracks, missing teeth, or body damage that needs attention."
  },
  {
    number: "02",
    title: "Cleaning",
    description: "Blades are cleaned to remove pitch, resin, and built-up material. This ensures accurate grinding and reveals any hidden damage."
  },
  {
    number: "03",
    title: "Precision Grinding",
    description: "Using CNC grinding equipment with diamond or CBN wheels, we restore each tooth to factory specifications. Coolant flow prevents heat damage."
  },
  {
    number: "04",
    title: "Quality Control",
    description: "Every sharpened blade undergoes measurement verification to ensure all angles, heights, and geometries meet specifications."
  }
];
---

<Layout 
  title="Sharpening and Repair | Carbide Saws Inc. High Point NC"
  description="Carbide Saws Inc. helps you keep up the quality and safety of your equipment by offering quality sharpening and repair. We maintain the quality of your carbide circular blades."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 ">
      <img src="/gallery-3.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <div class="inline-block bg-accent/20 border border-accent/30 rounded-full px-4 py-2 mb-6">
          <span class="text-accent font-semibold text-sm tracking-wider uppercase">CNC Precision Grinding</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">
          Sharpening and Repair
        </h1>
        <p class="text-xl text-gray-300 mb-8 leading-relaxed">
          Carbide Saws Inc. helps you keep up the quality and safety of your equipment 
          by offering quality sharpening and repair. We are fully equipped with the proper 
          tools to repair carbide saws and maintain the quality of your carbide circular blades.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Get a Sharpening Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Why Sharpen -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">
            Regular Maintenance Saves Money
          </h2>
          <div class="prose-custom">
            <p>
              Regularly sharpening your blades will keep them in pristine condition, working 
              effectively for years to come. Instead of wasting money on frequent blade replacements, 
              let us return yours to their original sharpness and shine with our proprietary sharpening system.
            </p>
            <p>
              Professional maintenance and repair of your carbide saw and blades ensures that your 
              equipment remains the best product. We maintain the quality and safety of your equipment 
              by offering quality sharpening and repair services.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="bg-light p-4 rounded-xl text-center">
              <div class="text-3xl font-bold text-accent" style="font-family: 'Roboto Slab', serif;">Save</div>
              <div class="text-gray-600">Up to 70% vs New</div>
            </div>
            <div class="bg-light p-4 rounded-xl text-center">
              <div class="text-3xl font-bold text-accent" style="font-family: 'Roboto Slab', serif;">Extend</div>
              <div class="text-gray-600">Blade Life 3-5x</div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/gallery-1.jpg" alt="Saw sharpening" class="img-rounded w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- Sharpening Types -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Types of Sharpening</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We sharpen all types of industrial cutting tools using specialized equipment 
          and techniques for each application.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {sharpeningTypes.map(type => (
          <div class="feature-card card-hover">
            <h3 class="text-2xl font-bold text-primary mb-4" style="font-family: 'Roboto Slab', serif;">{type.title}</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">{type.description}</p>
            <div class="flex flex-wrap gap-2">
              {type.specs.map(spec => (
                <span class="bg-light px-4 py-2 rounded-full text-sm font-medium text-primary">{spec}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Our Sharpening Process</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every blade receives our meticulous multi-step process to ensure optimal results.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {processSteps.map((step, index) => (
          <div class="relative">
            <div class="text-6xl font-bold text-accent/20 mb-4" style="font-family: 'Roboto Slab', serif;">{step.number}</div>
            <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">{step.title}</h3>
            <p class="text-gray-600 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Section -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Advanced Grinding Technology</h2>
          <div class="prose-custom">
            <p>
              Our sharpening facility features state-of-the-art CNC grinding equipment capable of 
              maintaining tolerances within thousandths of an inch. This precision ensures that 
              every tooth on your blade is identical to the next, producing cleaner cuts and 
              longer blade life.
            </p>
            <p>
              We are fully equipped with the proper tools to repair carbide saws and maintain 
              the quality of your carbide circular blades. Our proprietary sharpening system 
              returns your blades to their original sharpness and shine.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-primary p-6 rounded-2xl text-white">
            <div class="text-4xl font-bold text-accent mb-2" style="font-family: 'Roboto Slab', serif;">±0.001"</div>
            <div class="text-gray-300">Precision Tolerance</div>
          </div>
          <div class="bg-accent p-6 rounded-2xl text-primary">
            <div class="text-4xl font-bold mb-2" style="font-family: 'Roboto Slab', serif;">300%</div>
            <div class="font-semibold">Life Extension</div>
          </div>
          <div class="bg-light p-6 rounded-2xl">
            <div class="text-4xl font-bold text-primary mb-2" style="font-family: 'Roboto Slab', serif;">24-48h</div>
            <div class="text-gray-600">Turnaround Time</div>
          </div>
          <div class="bg-primary p-6 rounded-2xl text-white">
            <div class="text-4xl font-bold text-accent mb-2" style="font-family: 'Roboto Slab', serif;">All</div>
            <div class="text-gray-300">Brands & Types</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding gradient-hero text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Ready to Restore Your Blades?</h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto leading-relaxed">
        Contact us for a sharpening quote. We service all brands and types of industrial cutting tools.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Get a Quote
        </a>
        <a href="tel:800-578-7197" class="btn-secondary text-white border-white/50 hover:bg-white hover:text-primary text-lg px-8 py-4">
          Call (336) 434-2111
        </a>
      </div>
    </div>
  </section>
</Layout>
