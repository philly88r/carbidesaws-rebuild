# src/pages/contact.astro (11922 bytes)

---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  {
    title: "Location",
    content: "701 Garrison St, High Point, NC 27260",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`
  },
  {
    title: "Service Area",
    content: "NC, SC, VA, Eastern TN",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`
  },
  {
    title: "Hours",
    content: "Monday - Friday: 8AM - 5PM EST",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
  },
  {
    title: "Turnaround",
    content: "24-48 Hours Standard Service",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  }
];

const services = [
  "Saw blade sharpening",
  "Tip replacement and repair",
  "Custom blade manufacturing",
  "Cutter head design",
  "Technical consulting",
  "Emergency rush service"
];
---

<Layout 
  title="Contact Us | Carbide Saws Inc. High Point NC"
  description="Contact Carbide Saws Inc. for saw sharpening quotes, blade repair assessments, and custom manufacturing inquiries. Serving NC, SC, VA, Eastern TN."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">
          Contact Carbide Saws Inc.
        </h1>
        <p class="text-xl text-gray-300 mb-8 leading-relaxed">
          Ready to optimize your cutting operation? Our team is standing by to provide 
          quotes, technical advice, and expert service.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info Grid -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 -mt-32 relative z-10">
        {contactInfo.map(info => (
          <div class="feature-card text-center card-hover">
            <div class="w-14 h-14 bg-accent rounded-xl flex items-center justify-center mx-auto mb-4 text-primary">
              <fragment set:html={info.icon} />
            </div>
            <h3 class="text-lg font-bold text-primary mb-2" style="font-family: 'Roboto Slab', serif;">{info.title}</h3>
            <p class="text-gray-600">{info.content}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Get in Touch</h2>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            Whether you need a sharpening quote, have questions about custom blades, 
            or want technical advice, we're here to help. Fill out the form or contact 
            us directly using the information below.
          </p>
          
          <div class="space-y-6 mb-8">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-accent rounded-xl flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary mb-1">Email</h3>
                <p class="text-gray-600">sales@carbidesawsinc.com</p>
                <p class="text-sm text-gray-500">For quotes and general inquiries</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-accent rounded-xl flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary mb-1">Phone</h3>
                <p class="text-gray-600">(336) 882-6835</p>
                <p class="text-sm text-gray-500">Monday - Friday, 8AM - 5PM EST</p>
              </div>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-lg">
            <h3 class="font-bold text-primary mb-4" style="font-family: 'Roboto Slab', serif;">Services We Quote</h3>
            <ul class="space-y-2">
              {services.map(service => (
                <li class="flex items-center text-gray-600">
                  <svg class="w-5 h-5 text-accent mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  {service}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Quote Request Info -->
        <div>
          <div class="bg-white p-8 rounded-2xl shadow-lg">
            <h3 class="text-2xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Request a Quote</h3>
            <p class="text-gray-600 mb-6">
              For fastest service, please email us directly or call. For sharpening and repair quotes, 
              include the following information:
            </p>
            
            <div class="space-y-4 mb-8">
              <div class="bg-light p-4 rounded-xl">
                <h4 class="font-bold text-primary mb-2">For Sharpening/Repairs:</h4>
                <ul class="text-gray-600 space-y-1 text-sm">
                  <li>• Blade diameter and arbor size</li>
                  <li>• Number of teeth</li>
                  <li>• Blade type (carbide, HSS, etc.)</li>
                  <li>• Condition description</li>
                  <li>• Quantity</li>
                </ul>
              </div>
              
              <div class="bg-light p-4 rounded-xl">
                <h4 class="font-bold text-primary mb-2">For Custom Blades:</h4>
                <ul class="text-gray-600 space-y-1 text-sm">
                  <li>• Material to be cut</li>
                  <li>• Machine specifications</li>
                  <li>• Current blade issues</li>
                  <li>• Desired quantity</li>
                </ul>
              </div>
            </div>

            <div class="flex flex-col gap-4">
              <a href="mailto:sales@carbidesawsinc.com" class="btn-primary text-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                Email Us Now
              </a>
              <a href="tel:336-882-6835" class="btn-secondary justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Call (336) 882-6835
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section-padding bg-primary text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Our Service Area</h2>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          We provide pickup and delivery throughout our service region. 
          Outside our local area? We ship nationwide!
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl text-center border border-white/20">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="text-xl font-bold text-accent mb-1">North Carolina</h3>
          <p class="text-gray-400 text-sm">Full coverage</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl text-center border border-white/20">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="text-xl font-bold text-accent mb-1">South Carolina</h3>
          <p class="text-gray-400 text-sm">Full coverage</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl text-center border border-white/20">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="text-xl font-bold text-accent mb-1">Virginia</h3>
          <p class="text-gray-400 text-sm">Full coverage</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl text-center border border-white/20">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="text-xl font-bold text-accent mb-1">Eastern Tennessee</h3>
          <p class="text-gray-400 text-sm">Regional coverage</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Ready to Get Started?</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        Whether you need a single blade sharpened or a complete custom cutting solution, 
        we're here to help. Contact us today for a free quote.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:sales@carbidesawsinc.com" class="btn-primary text-lg px-8 py-4">
          Email for Quote
        </a>
        <a href="tel:336-882-6835" class="btn-secondary text-lg px-8 py-4">
          Call Now
        </a>
      </div>
    </div>
  </section>
</Layout>