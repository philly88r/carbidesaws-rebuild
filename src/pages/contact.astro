---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us | Industrial Saw Services & Support"
  description="Contact CarbideSaws.com for saw sharpening quotes, blade repair assessments, and custom manufacturing inquiries. Technical support for industrial cutting operations."
>
  <section class="gradient-hero text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Contact Industrial Sales</h1>
        <p class="text-xl text-blue-100">
          Ready to optimize your cutting operation? Our application engineers are standing by.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6">Get in Touch</h2>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary">Email</h3>
                <p class="text-gray-600">sales@carbidesaws.com</p>
                <p class="text-sm text-gray-500">Quotes and technical inquiries</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary">Phone</h3>
                <p class="text-gray-600">1-800-SAW-TECH</p>
                <p class="text-sm text-gray-500">Monday - Friday, 8AM - 5PM EST</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary">Turnaround</h3>
                <p class="text-gray-600">24-48 Hours Standard</p>
                <p class="text-sm text-gray-500">Emergency service available</p>
              </div>
            </div>
          </div>

          <div class="mt-10 p-6 bg-gray-50 rounded-xl">
            <h3 class="font-bold text-primary mb-3">What to Include in Your Inquiry</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• Saw make and model</li>
              <li>• Blade diameter and arbor size</li>
              <li>• Material being cut</li>
              <li>• Cutting issues experienced</li>
              <li>• Desired turnaround time</li>
            </ul>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-primary mb-6">Request a Quote</h2>
          <p class="text-gray-600 mb-6">
            For fastest service, email us directly with your blade specifications and requirements. 
            Our engineers typically respond within 2 business hours.
          </p>
          
          <a href="mailto:sales@carbidesaws.com" class="block w-full bg-secondary text-white text-center font-bold py-4 rounded-lg hover:bg-primary transition mb-6">
            Email Sales Team
          </a>

          <div class="border-t border-gray-200 pt-6">
            <h3 class="font-bold text-primary mb-4">Service Areas</h3>
            <div class="grid grid-cols-2 gap-3 text-gray-600">
              <div>• Sawmill Operations</div>
              <div>• Metal Fabrication</div>
              <div>• Cabinet Shops</div>
              <div>• Industrial Manufacturing</div>
              <div>• Countertop Fabrication</div>
              <div>• Pallet Manufacturing</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
