---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "Custom Design",
    description: "We design blades specifically for your material and cutting requirements, optimizing tooth geometry, grade selection, and plate design."
  },
  {
    title: "Premium Materials",
    description: "We use only high-quality carbide grades and precision-ground steel plates from trusted suppliers."
  },
  {
    title: "Expert Engineering",
    description: "Our engineers have decades of experience designing blades for the most demanding applications."
  },
  {
    title: "Fast Turnaround",
    description: "Most custom orders ship within 2-3 weeks. Rush service available when you need blades fast."
  }
];

const carbideGrades = [
  {
    grade: "C-2",
    cobalt: "6-10%",
    description: "General purpose grade offering the best balance of hardness and toughness. Ideal for softwoods and general cutting.",
    applications: "Softwoods, hardwoods, plywood, MDF"
  },
  {
    grade: "C-3",
    cobalt: "4-6%",
    description: "Harder grade with excellent wear resistance. Perfect for abrasive materials and high-volume production.",
    applications: "Particleboard, MDF, laminates, plastics"
  },
  {
    grade: "C-4",
    cobalt: "2-4%",
    description: "Maximum hardness for extreme wear resistance. Best for non-ferrous metals and high-silica woods.",
    applications: "Aluminum, brass, high-silica hardwoods"
  },
  {
    grade: "Micro-Grain",
    cobalt: "Varies",
    description: "Sub-micron grain structure provides superior edge retention and finish quality.",
    applications: "Fine finish work, premium applications"
  }
];

const processSteps = [
  "Consultation - We discuss your application, material, and requirements",
  "Design - Our engineers create a blade design optimized for your needs",
  "Quote - We provide a detailed quote with specifications and delivery time",
  "Manufacturing - Your blades are precision-manufactured to exact tolerances",
  "Quality Control - Every blade is inspected and tested before shipment",
  "Delivery - Your custom blades arrive ready to cut"
];
---

<Layout 
  title="Custom Saw Blades & Cutter Heads | Carbide Saws Inc. High Point NC"
  description="Custom engineered saw blades and cutter heads designed for your specific application. Premium carbide grades, precision manufacturing. Serving NC, SC, VA, Eastern TN."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 ">
      <img src="/gallery-3.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <div class="inline-block bg-accent/20 border border-accent/30 rounded-full px-4 py-2 mb-6">
          <span class="text-accent font-semibold text-sm tracking-wider uppercase">Engineered to Order</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">
          Custom Saw Blades & Cutter Heads
        </h1>
        <p class="text-xl text-gray-300 mb-8 leading-relaxed">
          When standard blades don't meet your needs, we engineer custom cutting solutions 
          designed specifically for your material, machine, and application requirements. 
          From concept to cutting, we deliver precision performance.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Start Your Custom Design
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Why Choose Custom?</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Standard blades are designed for general use. When you have specific requirements, 
          custom-engineered blades deliver superior performance and longer life.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {features.map(feature => (
          <div class="feature-card card-hover text-center">
            <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">{feature.title}</h3>
            <p class="text-gray-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Carbide Grades -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Carbide Grade Selection</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We offer a full range of carbide grades to match your specific cutting requirements. 
          Our engineers will recommend the optimal grade for your application.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {carbideGrades.map(grade => (
          <div class="feature-card card-hover">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-2xl font-bold text-primary" style="font-family: 'Roboto Slab', serif;">Grade {grade.grade}</h3>
              <span class="bg-accent/20 text-primary px-3 py-1 rounded-full text-sm font-semibold">{grade.cobalt} Cobalt</span>
            </div>
            <p class="text-gray-600 mb-4">{grade.description}</p>
            <div>
              <span class="text-sm font-semibold text-primary">Best for:</span>
              <p class="text-gray-600">{grade.applications}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Specifications -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Custom Specifications Available</h2>
          <p class="text-xl text-gray-600 mb-8">
            We can manufacture blades to your exact specifications or design them based on your requirements.
          </p>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Diameter</div>
              <div class="text-gray-600">4" to 84"+</div>
            </div>
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Kerf Width</div>
              <div class="text-gray-600">0.125" to 0.375"+</div>
            </div>
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Arbor Size</div>
              <div class="text-gray-600">1" to 2.5"+</div>
            </div>
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Tooth Count</div>
              <div class="text-gray-600">12 to 120+</div>
            </div>
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Hook Angle</div>
              <div class="text-gray-600">Custom to application</div>
            </div>
            <div class="bg-light p-4 rounded-xl">
              <div class="font-bold text-primary mb-1">Tooth Style</div>
              <div class="text-gray-600">ATB, FT, TCG, Hi-ATB</div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/gallery-1.jpg" alt="Custom Blades" class="img-rounded w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section-padding bg-primary text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/gallery-2.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Our Custom Design Process</h2>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          From initial consultation to final delivery, we guide you through every step 
          of the custom blade design process.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {processSteps.map((step, index) => (
          <div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl border border-white/20">
            <div class="text-4xl font-bold text-accent mb-3" style="font-family: 'Roboto Slab', serif;">0{index + 1}</div>
            <p class="text-gray-200 leading-relaxed">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Ready for Custom Blades?</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        Contact our engineering team to discuss your custom blade requirements. 
        We'll help you design the perfect cutting solution for your application.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Request Custom Quote
        </a>
        <a href="tel:1-800-555-0123" class="btn-secondary text-lg px-8 py-4">
          Call to Discuss
        </a>
      </div>
    </div>
  </section>
</Layout>
