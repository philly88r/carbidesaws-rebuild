---
import Layout from '../layouts/Layout.astro';

const milestones = [
  { year: "1954", event: "Carbide Saws Inc. founded by Casey Goodman in High Point, NC" },
  { year: "1960", event: "Casey Goodman passes; wife Jean takes over the helm" },
  { year: "1980s", event: "Added Burnette LTD to provide economical tooling services from quality manufacturers" },
  { year: "Today", event: "Continuing the family tradition, manufacturing products in High Point, NC for over 70 years" }
];

const capabilities = [
  {
    title: "CNC Grinding Equipment",
    description: "Computer-controlled precision grinding machines capable of maintaining tolerances within ±0.001 inch."
  },
  {
    title: "Diamond & CBN Wheels",
    description: "Premium grinding media specifically selected for carbide, cermet, and high-speed steel."
  },
  {
    title: "Brazing Station",
    description: "High-temperature silver brazing equipment for professional tip replacement."
  },
  {
    title: "Tensioning Equipment",
    description: "Professional blade tensioning systems to restore proper body stiffness."
  },
  {
    title: "Quality Control",
    description: "Digital measuring equipment and test cutting stations to verify every repair."
  },
  {
    title: "Custom Manufacturing",
    description: "Complete blade building capabilities from raw plate to finished cutter."
  }
];
---

<Layout 
  title="About Us | Carbide Saws Inc. High Point NC"
  description="Founded in 1954 by Casey Goodman, Carbide Saws Inc. has served the Eastern United States for over 70 years. Family owned and operated, providing saw blade manufacturing and servicing."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 ">
      <img src="/carbidesaws-rebuild/gallery-1.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <div class="inline-block bg-accent/20 border border-accent/30 rounded-full px-4 py-2 mb-6">
          <span class="text-accent font-semibold text-sm tracking-wider uppercase">Since 1954</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">
          About Carbide Saws Inc. & Burnette, Ltd.
        </h1>
        <p class="text-xl text-gray-300 mb-8 leading-relaxed">
          Founded by Casey Goodman in 1954, we've been your GO-TO-SOURCE for the manufacture 
          and servicing of saw blades and custom cutter heads for over 70 years.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Our Story</h2>
          <div class="prose-custom">
            <p>
              Carbide Saws Inc., founded by Casey Goodman in 1954, filled a demand from customers 
              in the Eastern United States who were in need of "in-house" manufactured tools, 
              hammering, tensioning and smithing services. The business grew and thrived through 
              Mr. Goodman's passing in 1960 and his wife Jean's subsequent decision to take over 
              the helm at that time.
            </p>
            <p>
              In the early 1980s, Carbide Saws Inc. added Burnette LTD to its repertoire to provide 
              economical and innovative tooling services from reputable, quality manufacturers. 
              Fast forward to today, and this strong family business continues to manufacture 
              products at its facility in High Point, North Carolina.
            </p>
            <p>
              In business for over 70 years, we have the expert "EDGE" when it comes to the 
              manufacture and servicing of saw blades and custom cutter heads. We also produce 
              precision machine parts, wear parts and any related metal components.
            </p>
            <p>
              At Carbide Saws Inc, we "slice" through the competition by providing you the quality 
              you demand in a timely and efficient manner. Your satisfaction is our number one priority.
            </p>
          </div>
          <div class="grid grid-cols-3 gap-6 mt-8">
            <div class="text-center p-4 bg-light rounded-2xl">
              <div class="text-4xl font-bold text-accent" style="font-family: 'Roboto Slab', serif;">70+</div>
              <div class="text-gray-600 text-sm">Years in Business</div>
            </div>
            <div class="text-center p-4 bg-light rounded-2xl">
              <div class="text-4xl font-bold text-accent" style="font-family: 'Roboto Slab', serif;">1954</div>
              <div class="text-gray-600 text-sm">Year Founded</div>
            </div>
            <div class="text-center p-4 bg-light rounded-2xl">
              <div class="text-4xl font-bold text-accent" style="font-family: 'Roboto Slab', serif;">Family</div>
              <div class="text-gray-600 text-sm">Owned & Operated</div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/carbidesaws-rebuild/gallery-2.jpg" alt="Carbide Saws Workshop" class="img-rounded w-full" />
          <div class="absolute -bottom-6 -right-6 bg-accent text-primary p-6 rounded-2xl shadow-xl hidden md:block">
            <div class="text-3xl font-bold" style="font-family: 'Roboto Slab', serif;">Est. 1954</div>
            <div class="text-lg font-semibold">High Point, NC</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Our History</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Four generations of serving the woodworking and metalworking industries
        </p>
      </div>

      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-accent/30 hidden md:block"></div>
        <div class="space-y-8">
          {milestones.map((milestone, index) => (
            <div class={`flex flex-col md:flex-row items-center ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
              <div class="w-full md:w-1/2 md:px-8">
                <div class={`feature-card ${index % 2 === 0 ? 'md:text-left' : 'md:text-right'}`}>
                  <div class="text-2xl font-bold text-accent mb-2" style="font-family: 'Roboto Slab', serif;">{milestone.year}</div>
                  <p class="text-gray-700">{milestone.event}</p>
                </div>
              </div>
              <div class="w-8 h-8 bg-accent rounded-full border-4 border-white shadow-lg z-10 my-4 md:my-0 hidden md:block"></div>
              <div class="w-full md:w-1/2 md:px-8"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">What We Do</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We offer a wide array of quality brands and services to make your production more efficient
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <div class="feature-card text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <img src="/carbidesaws-rebuild/icon-sharpening.png" alt="" class="w-10 h-10 object-contain" />
          </div>
          <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">Sharpening & Repair</h3>
          <p class="text-gray-600">Expert sharpening service for all types of carbide tipped saw blades and cutting tools.</p>
        </div>
        <div class="feature-card text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <img src="/carbidesaws-rebuild/icon-custom.png" alt="" class="w-10 h-10 object-contain" />
          </div>
          <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">Custom Manufacturing</h3>
          <p class="text-gray-600">In-house manufactured tools including saw blades, custom cutter heads, and precision parts.</p>
        </div>
        <div class="feature-card text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <img src="/carbidesaws-rebuild/icon-repair.png" alt="" class="w-10 h-10 object-contain" />
          </div>
          <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">Hammering & Tensioning</h3>
          <p class="text-gray-600">Professional smithing services to maintain the quality and performance of your blades.</p>
        </div>
      </div>

      <div class="bg-light p-8 rounded-2xl">
        <h3 class="text-2xl font-bold text-primary mb-4 text-center" style="font-family: 'Roboto Slab', serif;">Products We Offer</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Carbide Tipped Sawblades</span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Carbide Tipped MTP Cutters</span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Carbide Tipped Router Bits</span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Precision Machine Parts</span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Wear Parts</span>
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-accent mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-gray-700">Related Metal Components</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section-padding bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Our Capabilities</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          State-of-the-art equipment and decades of expertise at your service
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {capabilities.map(cap => (
          <div class="feature-card card-hover">
            <h3 class="text-xl font-bold text-primary mb-3" style="font-family: 'Roboto Slab', serif;">{cap.title}</h3>
            <p class="text-gray-600">{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section-padding bg-primary text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Why Choose Carbide Saws Inc.?</h2>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          At Carbide Saws, if we can't get it sharp, it ain't dull!
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-accent mb-3" style="font-family: 'Roboto Slab', serif;">Authorized Service</h3>
          <p class="text-gray-300">Freud authorized service center with factory-trained technicians</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-accent mb-3" style="font-family: 'Roboto Slab', serif;">Fast Turnaround</h3>
          <p class="text-gray-300">Quality work delivered quickly to minimize your downtime</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-accent mb-3" style="font-family: 'Roboto Slab', serif;">Convenient Service</h3>
          <p class="text-gray-300">Pickup and delivery throughout NC, SC, VA, Eastern TN</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 text-center">
          <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-accent mb-3" style="font-family: 'Roboto Slab', serif;">Nationwide</h3>
          <p class="text-gray-300">Shipping available to customers across the United States</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Work With Us</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        Experience the difference that 70+ years of expertise makes. We slice through 
        the competition by providing you the quality you demand.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/carbidesaws-rebuild/contact" class="btn-primary text-lg px-8 py-4">
          Get a Free Quote
        </a>
        <a href="/carbidesaws-rebuild/carbide-saw-sharpening" class="btn-secondary text-lg px-8 py-4">
          Our Services
        </a>
      </div>
    </div>
  </section>
</Layout>
