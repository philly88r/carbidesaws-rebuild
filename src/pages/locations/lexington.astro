---
import Layout from '../../layouts/Layout.astro';
const cityName = "Lexington";
const schema = {"@context":"https://schema.org","@type":"LocalBusiness","name":"Carbide Saws Inc.","telephone":"+1-800-578-7197","areaServed":{"@type":"City","name":"Lexington, NC"}};
---
<Layout title={`Saw Blade Sharpening in ${cityName}, NC`} description={`Professional saw blade sharpening and repair in ${cityName}, NC. Serving Davidson County since 1954.`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<section class="gradient-hero text-white py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Sharpening in {cityName}, NC</h1>
      <p class="text-xl text-gray-300 mb-8">Professional saw blade services for Lexington and Davidson County. Pickup & delivery available.</p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Get a Free Quote</a>
    </div>
  </div>
</section>
<section class="section-padding bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="prose-custom">
      <h2>Saw Blade Services in Lexington, NC</h2>
      <p>Carbide Saws Inc. provides expert saw blade sharpening and repair services to Lexington businesses and manufacturers throughout Davidson County. Our CNC precision grinding equipment restores your blades to factory specifications.</p>
      <p>We offer convenient pickup and delivery service to Lexington, making it easy to keep your cutting tools in peak condition. Contact us today for a free quote on your sharpening or repair needs.</p>
    </div>
  </div>
</section>
</Layout>
