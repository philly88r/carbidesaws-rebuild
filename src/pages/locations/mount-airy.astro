---
import Layout from '../../layouts/Layout.astro';
const cityName = "Mount Airy";
const schema = {"@context":"https://schema.org","@type":"LocalBusiness","name":"Carbide Saws Inc.","telephone":"+1-336-434-2111","areaServed":{"@type":"City","name":"Mount Airy, NC"}};
---
<Layout title={`Saw Blade Sharpening in ${cityName}, NC`} description={`Professional saw blade sharpening and repair in ${cityName}, NC. Serving Surry County and the Foothills region.`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<section class="gradient-hero text-white py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/95 to-primary/80"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Sharpening in {cityName}, NC</h1>
      <p class="text-xl text-gray-300 mb-8">Professional saw blade services for Mount Airy and Surry County. Pickup & delivery available.</p>
      <a href="/carbidesaws-rebuild/contact" class="btn-primary text-lg px-8 py-4">Get a Free Quote</a>
    </div>
  </div>
</section>
<section class="section-padding bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Services in Mount Airy, NC</h2>
    <p class="text-lg text-gray-600 mb-6">Mount Airy, known as Mayberry and the hometown of Andy Griffith, is also home to a thriving community of woodworkers and manufacturers. Carbide Saws Inc. is proud to extend our professional saw blade services to the Granite City and surrounding Surry County.</p>
    <p class="text-lg text-gray-600">Whether you're crafting fine furniture, running a millwork operation, or managing an industrial facility in Mount Airy, we provide the sharpening, repair, and custom manufacturing services you need to keep production running smoothly.</p>
  </div>
</section>
</Layout>
