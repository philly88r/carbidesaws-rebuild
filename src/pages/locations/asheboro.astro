---
import Layout from '../../layouts/Layout.astro';
const cityName = "Asheboro";
const schema = {"@context":"https://schema.org","@type":"LocalBusiness","name":"Carbide Saws Inc.","telephone":"+1-336-434-2111","areaServed":{"@type":"City","name":"Asheboro, NC"}};
---
<Layout title={`Saw Blade Sharpening in ${cityName}, NC`} description={`Professional saw blade sharpening and repair in ${cityName}, NC. Serving Randolph County since 1954.`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<section class="gradient-hero text-white py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Sharpening in {cityName}, NC</h1>
      <p class="text-xl text-gray-300 mb-8">Professional saw blade services for Asheboro and Randolph County. Pickup & delivery available.</p>
      <a href="/carbidesaws-rebuild/contact" class="btn-primary text-lg px-8 py-4">Get a Free Quote</a>
    </div>
  </div>
</section>
<section class="section-padding bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="prose-custom">
      <h2>Saw Blade Services in Asheboro, NC</h2>
      <p>Carbide Saws Inc. proudly serves the Asheboro community and surrounding Randolph County area with professional saw blade sharpening, repair, and custom manufacturing services. Our family-owned business has been helping North Carolina manufacturers since 1954.</p>
      <p>We understand the needs of Asheboro's diverse manufacturing base, from woodworking shops to industrial facilities. Our expert technicians can sharpen and repair all types of cutting tools, extending blade life and improving cut quality.</p>
    </div>
  </div>
</section>
</Layout>
