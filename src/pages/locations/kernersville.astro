---
import Layout from '../../layouts/Layout.astro';
const cityName = "Kernersville";
const schema = {"@context":"https://schema.org","@type":"LocalBusiness","name":"Carbide Saws Inc.","telephone":"+1-800-578-7197","areaServed":{"@type":"City","name":"Kernersville, NC"}};
---
<Layout title={`Saw Blade Sharpening in ${cityName}, NC`} description={`Professional saw blade sharpening and repair in ${cityName}, NC. Triad area service with pickup & delivery.`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<section class="gradient-hero text-white py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/75 to-primary/60"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Sharpening in {cityName}, NC</h1>
      <p class="text-xl text-gray-300 mb-8">Professional saw blade services for Kernersville and the Triad area. Pickup & delivery available.</p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Get a Free Quote</a>
    </div>
  </div>
</section>
<section class="section-padding bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-primary mb-6" style="font-family: 'Roboto Slab', serif;">Saw Blade Services in Kernersville, NC</h2>
    <p class="text-lg text-gray-600 mb-6">Kernersville's strategic location in the heart of the Triad makes it a hub for manufacturing and distribution. Carbide Saws Inc. provides professional saw blade sharpening and repair services to Kernersville businesses, with convenient pickup and delivery options.</p>
    <p class="text-lg text-gray-600">Whether you need precision sharpening for cabinet making or industrial blade repair, our experienced technicians deliver quality results with fast turnaround times.</p>
  </div>
</section>
</Layout>
